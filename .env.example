# ─────────────────────────────────────────────────────────────
#  Enterprise Knowledge Assistant — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── LLM (Cloud API — required, keeps the laptop RAM-free) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.2

# ── Embeddings (local, no API key needed) ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=enterprise_docs

# ── SQLite (dev) / PostgreSQL (prod) ──
DATABASE_URL=sqlite:///./data/enterprise_rag.db
# DATABASE_URL=postgresql://user:password@localhost:5432/enterprise_rag

# ── JWT Auth ──
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App Settings ──
APP_NAME=Enterprise Knowledge Assistant
DEBUG=true
LOG_LEVEL=INFO

# ── File Upload ──
UPLOAD_DIR=./data/raw
MAX_UPLOAD_SIZE_MB=50

# ── RAG Settings ──
CHUNK_SIZE=700
CHUNK_OVERLAP=125
TOP_K_DEFAULT=5

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=30

# ── Production Storage (leave blank in dev) ──
# S3_BUCKET=your-s3-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
